#include <windows.h>
#include <iostream>
#include <ctype.h>

// Определяем прототипы функций из DLL
typedef void (*InitWorldFunc)(int);
typedef int (*ApplyGravityFunc)(int);
typedef void (*RenderWorldFunc)(int, int);
typedef int (*ProcessActionFunc)(char, int, int);

int main() {
    // Динамически загружаем нашу DLL
    HMODULE hDll = LoadLibraryA("engine.dll");
    if (!hDll) {
        std::cout << "Критическая ошибка: Не найдена библиотека engine.dll!\n";
        std::system("pause");
        return 1;
    }

    // Связываем функции
    InitWorldFunc InitWorld = (InitWorldFunc)GetProcAddress(hDll, "InitWorld");
    ApplyGravityFunc ApplyGravity = (ApplyGravityFunc)GetProcAddress(hDll, "ApplyGravity");
    RenderWorldFunc RenderWorld = (RenderWorldFunc)GetProcAddress(hDll, "RenderWorld");
    ProcessActionFunc ProcessAction = (ProcessActionFunc)GetProcAddress(hDll, "ProcessAction");

    const int WORLD_SIZE = 40;
    int playerPos = 12;
    bool isRunning = true;

    InitWorld(WORLD_SIZE);

    while (isRunning) {
        playerPos = ApplyGravity(playerPos);
        RenderWorld(WORLD_SIZE, playerPos);

        char input;
        std::cin >> input;
        input = tolower(input);

        if (input == 'x') {
            isRunning = false;
        } else {
            playerPos = ProcessAction(input, playerPos, WORLD_SIZE);
        }
    }

    FreeLibrary(hDll);
    return 0;
}
